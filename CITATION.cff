type: software
title: "Recurrent Inference Machines with Generative Initialization for Image Inverse Problems"
authors:
  - family-names: "Vasquez"
    given-names: "Ernesto Jose"
    affiliation: "Universidad Industrial de Santander"
  - family-names: "Ribero"
